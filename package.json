{
  "name": "ai-cli-manager",
  "version": "0.1.0",
  "description": "AI Coding CLI Tools Manager",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "keywords": ["cli", "ai", "tools", "manager"],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.ai-cli-manager.app",
    "productName": "AI CLI Manager",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "${GITHUB_USER}",
      "repo": "ai-cli-manager"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "resources/icon.png",
      "category": "Development"
    },
    "files": [
      "src/**/*",
      "resources/**/*"
    ]
  }
}
